{
	"name": "order-up",
	"type": "module",
	"scripts": {
		"start": "bun run src/index.ts",
		"dev": "bun run --watch src/index.ts",
		"format": "bunx biome format --write",
		"lint": "bunx biome lint --write",
		"check": "bunx biome check --write",
		"type-check": "bunx tsc --noEmit",
		"emulator": "firebase emulators:start",
		"db:generate-types": "bunx supabase gen types typescript --project-id 'pgqqihxvfsgendocqmeo' --schema public > db/database.types.ts"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.108.2",
		"bcrypt": "^6.0.0",
		"eventsource": "^4.0.1",
		"hono": "^4.12.27",
		"nanoid": "^5.1.16",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/bcrypt": "^6.0.0",
		"@types/bun": "^1.3.14",
		"supabase": "^2.107.0"
	},
	"module": "index.ts",
	"peerDependencies": {
		"typescript": "^5.7.3"
	}
}
